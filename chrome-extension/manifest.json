{
  "manifest_version": 3,
  "name": "paper-manager importer",
  "version": "0.1.0",
  "description": "Import DOI, arXiv, and accessible PDF files into paper-manager.",
  "permissions": [
    "activeTab",
    "downloads",
    "nativeMessaging",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Import to paper-manager"
  },
  "background": {
    "service_worker": "service_worker.js"
  }
}
